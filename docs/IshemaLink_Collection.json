            "body": {
              "mode": "raw",
              "raw": "{\"nid\": \"1234567890123456\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify-nid/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "verify-nid"]
            }
          }
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Token {{token}}"
